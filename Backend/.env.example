# Supabase project API settings.
# Found in Supabase Dashboard -> Project Settings -> API.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Supabase Postgres connection.
# Option A: paste the full SQLAlchemy async URL.
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Option B: leave DATABASE_URL empty and fill these pieces instead.
SUPABASE_DB_HOST=db.YOUR_PROJECT_REF.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD

# JWT verification.
# Found in Supabase Dashboard -> Project Settings -> API -> JWT Settings.
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET
JWT_AUDIENCE=authenticated

# Frontend origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
